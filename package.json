{
  "name": "onofficejs",
  "version": "1.0.1",
  "description": "Unofficial TypeScript/JavaScript client for the onOffice API — community-maintained, not affiliated with onOffice GmbH",
  "keywords": [
    "onoffice",
    "onoffice-api",
    "real-estate",
    "crm",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/Felixfalk26/onofficejs#readme",
  "bugs": {
    "url": "https://github.com/Felixfalk26/onofficejs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Felixfalk26/onofficejs.git"
  },
  "license": "MIT",
  "author": "onofficejs contributors",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./constants": {
      "import": {
        "types": "./dist/constants/index.d.ts",
        "default": "./dist/constants/index.js"
      },
      "require": {
        "types": "./dist/constants/index.d.cts",
        "default": "./dist/constants/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "DISCLAIMER.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests examples",
    "lint:fix": "eslint src tests examples --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "example:estate-read": "tsx examples/01-estate-read.ts",
    "example:estate-search": "tsx examples/02-estate-search.ts",
    "example:marketplace-unlock": "tsx examples/03-marketplace-unlock.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^3.2.1",
    "eslint": "^9.28.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  }
}
